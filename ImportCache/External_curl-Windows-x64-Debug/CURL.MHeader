Property.CMakeOutputPath_CURL: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Tool_CURL_curl-ca-bundle"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_curl-ca-bundle"
	Target.BaseFileName "curl-ca-bundle"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "CMakeFiles"
				{
					%File `@('.'->MakeAbsolute())/CMakeFiles/curl-ca-bundle.rule`
					{
						Compile
						{
							Type "Custom"
							Custom_CommandLine `perl.exe @(`@('../../../../External/curl'->MakeAbsolute())/scripts/mk-ca-bundle.pl`->MakeAbsolute()->EscapeHost()) -b -l -u lib/ca-bundle.crt`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('.'->MakeAbsolute())`->MakeAbsolute()
							Custom_Outputs []
							Custom_Inputs [
								`@('../../../../External/curl'->MakeAbsolute())/scripts/mk-ca-bundle.pl`->MakeAbsolute()
							]
						}
					}
				}
			}
		}
	}
}
