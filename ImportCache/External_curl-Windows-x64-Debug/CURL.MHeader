					}
					%File `@('.'->MakeAbsolute())/docs/curl-config.1.rule`
					{
						Compile
						{
							Type "Custom"
							Custom_CommandLine `perl.exe @(`@('../../../../External/curl'->MakeAbsolute())/scripts/cd2nroff`->MakeAbsolute()->EscapeHost()) curl-config.md > @(`@(CMakeIntermediateDirectory)/External_curl/docs/curl-config.1`->MakeAbsolute()->EscapeHost())`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('../../../../External/curl'->MakeAbsolute())/docs`->MakeAbsolute()
							Custom_Outputs [
