%Target "Tool_CURL_tests"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_tests"
	Target.BaseFileName "tests"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "tests"
				{
					%Group "CMakeFiles"
					{
						%File `@('.'->MakeAbsolute())/tests/CMakeFiles/tests.rule`
						{
							Compile
							{
								Type "Custom"
								Custom_CommandLine `perl.exe @(`@('../../../../External/curl'->MakeAbsolute())/tests/runtests.pl`->MakeAbsolute()->EscapeHost()) !documentation $$TFLAGS`
								AllowNonExisting true
								Disabled false
								Custom_WorkingDirectory `@('.'->MakeAbsolute())/tests`->MakeAbsolute()
								Custom_Outputs []
								Custom_Inputs [
									`@('.'->MakeAbsolute())/src/curl.exe`->MakeAbsolute()
								]
							}
						}
					}
				}
			}
		}
	}
	%Dependency "Com_CURL_curl"
	{
		Dependency.Link false
	}
	%Dependency "Tool_CURL_testdeps"
	{
		Dependency.Link false
	}
}
