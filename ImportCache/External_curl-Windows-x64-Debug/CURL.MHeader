%Target "Tool_CURL_build-certs"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_build-certs"
	Target.BaseFileName "build-certs"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "tests"
				{
					%Group "certs"
					{
						%Group "CMakeFiles"
						{
							%File `@('.'->MakeAbsolute())/tests/certs/CMakeFiles/build-certs.rule`
						}
						%File `@('.'->MakeAbsolute())/tests/certs/test-ca.cacert.rule`
						{
							Compile
							{
								Type "Custom"
								Custom_CommandLine `perl.exe @(`@('../../../../External/curl'->MakeAbsolute())/tests/certs/genserv.pl`->MakeAbsolute()->EscapeHost()) test test-localhost.prm test-localhost.nn.prm test-localhost0h.prm test-localhost-san-first.prm test-localhost-san-last.prm test-client-cert.prm test-client-eku-only.prm`
								AllowNonExisting true
								Disabled false
								Custom_WorkingDirectory `@('.'->MakeAbsolute())/tests/certs`->MakeAbsolute()
								Custom_Outputs [
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-ca.cacert`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-ca.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-ca.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.crl`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.pub.der`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.pub.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.nn.crl`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.nn.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.nn.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.nn.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.nn.pub.der`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost.nn.pub.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost0h.crl`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost0h.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost0h.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost0h.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost0h.pub.der`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost0h.pub.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-first.crl`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-first.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-first.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-first.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-first.pub.der`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-first.pub.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-last.crl`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-last.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-last.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-last.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-last.pub.der`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-localhost-san-last.pub.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-client-cert.crl`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-client-cert.crt`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-client-cert.key`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-client-cert.pem`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-client-cert.pub.der`->MakeAbsolute(),
									`@(CMakeIntermediateDirectory)/External_curl/tests/certs/test-client-cert.pub.pem`->MakeAbsolute()
								]
								Custom_Inputs [
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/genserv.pl`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-ca.cnf`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-ca.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-localhost.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-localhost.nn.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-localhost0h.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-localhost-san-first.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-localhost-san-last.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-client-cert.prm`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/certs/test-client-eku-only.prm`->MakeAbsolute()
								]
							}
						}
					}
				}
			}
		}
	}
}
%Target "Tool_CURL_clean-certs"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_clean-certs"
	Target.BaseFileName "clean-certs"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "tests"
				{
					%Group "certs"
					{
						%Group "CMakeFiles"
						{
							%File `@('.'->MakeAbsolute())/tests/certs/CMakeFiles/clean-certs.rule`
							{
								Compile
								{
									Type "Custom"
									Custom_CommandLine `MToolCMake -E remove test-ca.cacert test-ca.crt test-ca.key test-localhost.crl test-localhost.crt test-localhost.key test-localhost.pem test-localhost.pub.der test-localhost.pub.pem test-localhost.nn.crl test-localhost.nn.crt test-localhost.nn.key test-localhost.nn.pem test-localhost.nn.pub.der test-localhost.nn.pub.pem test-localhost0h.crl test-localhost0h.crt test-localhost0h.key test-localhost0h.pem test-localhost0h.pub.der test-localhost0h.pub.pem test-localhost-san-first.crl test-localhost-san-first.crt test-localhost-san-first.key test-localhost-san-first.pem test-localhost-san-first.pub.der test-localhost-san-first.pub.pem test-localhost-san-last.crl test-localhost-san-last.crt test-localhost-san-last.key test-localhost-san-last.pem test-localhost-san-last.pub.der test-localhost-san-last.pub.pem test-client-cert.crl test-client-cert.crt test-client-cert.key test-client-cert.pem test-client-cert.pub.der test-client-cert.pub.pem test-*.csr test-*.der test-*.keyenc test-ca.cnt* test-ca.db* test-ca.raw* test-ca.srl`
									AllowNonExisting true
									Disabled false
									Custom_WorkingDirectory `@('.'->MakeAbsolute())/tests/certs`->MakeAbsolute()
									Custom_Outputs []
									Custom_Inputs []
								}
							}
						}
					}
				}
			}
		}
	}
}
