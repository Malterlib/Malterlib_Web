%Target "Com_CURL_tunits"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/curl'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_curl`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/src`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/tests/libtest`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/tests/tunit`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zstd/lib`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"CURL_STATICLIB",
			"HAVE_CONFIG_H",
			"UNITTESTS"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "CURL_tunits"
	Target.BaseFileName "tunits"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "tests"
				{
					%Group "tunit"
					{
						%File `@(CMakeIntermediateDirectory)/External_curl/tests/tunit/tunits.c`->MakeAbsolute()
						{
							Compile.AllowNonExisting true
							Compile.Type "C"
						}
						%File `@('.'->MakeAbsolute())/tests/tunit/tunits.c.rule`
						{
							Compile
							{
								Type "Custom"
								Custom_CommandLine `perl.exe @(`@('../../../../External/curl'->MakeAbsolute())/scripts/mk-unity.pl`->MakeAbsolute()->EscapeHost()) --test tool1394.c tool1604.c tool1621.c > tunits.c`
								AllowNonExisting true
								Custom_WorkingDirectory `@('.'->MakeAbsolute())/tests/tunit`->MakeAbsolute()
								Custom_Outputs [
									`@(CMakeIntermediateDirectory)/External_curl/tests/tunit/tunits.c`->MakeAbsolute()
								]
								Custom_Inputs [
									`@('../../../../External/curl'->MakeAbsolute())/scripts/mk-unity.pl`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/tunit/Makefile.inc`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/libtest/first.c`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/tunit/tool1394.c`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/tunit/tool1604.c`->MakeAbsolute(),
									`@('../../../../External/curl'->MakeAbsolute())/tests/tunit/tool1621.c`->MakeAbsolute()
								]
							}
						}
					}
				}
			}
		}
	}
	%Dependency "Lib_CURL_curltool"
	%Dependency "Lib_CURL_libcurl_static"
}
%Target "Com_CURL_units"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/curl'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_curl`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/tests/libtest`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/tests/unit`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zstd/lib`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BUILDING_LIBCURL",
			"CURL_STATICLIB",
			"HAVE_CONFIG_H",
			"UNITTESTS"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "CURL_units"
	Target.BaseFileName "units"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "tests"
				{
					%Group "unit"
					{
						%File `@(CMakeIntermediateDirectory)/External_curl/tests/unit/units.c`->MakeAbsolute()
						{
							Compile.AllowNonExisting true
							Compile.Type "C"
