%Target "Com_CURL_curl-example-cacertinmem"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/curl'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zstd/lib`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/boringssl/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"CURL_NO_OLDIES",
			"CURL_STATICLIB",
			"HAVE_CONFIG_H",
			"WIN32_LEAN_AND_MEAN",
			"_CRT_SECURE_NO_DEPRECATE"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "CURL_curl-example-cacertinmem"
	Target.BaseFileName "curl-example-cacertinmem"
	%Group "docs"
	{
		%File `@('../../../../External/curl'->MakeAbsolute())/docs/examples/cacertinmem.c`
		{
			Compile.Type "C"
		}
	}
	%Dependency "Lib_CURL_libcurl_static"
}
