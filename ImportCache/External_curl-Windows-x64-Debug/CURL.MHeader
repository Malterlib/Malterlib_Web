%Target "Tool_CURL_curlu-unitprotos"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_curlu-unitprotos"
	Target.BaseFileName "curlu-unitprotos"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "lib"
				{
					%Group "CMakeFiles"
					{
						%File `@('.'->MakeAbsolute())/lib/CMakeFiles/curlu-unitprotos.rule`
					}
					%File `@('.'->MakeAbsolute())/lib/unitprotos.h.rule`
					{
						Compile
