# This should most probably benefit from getting a "Requires:" field added
# dynamically by configure.
#
prefix=C:/Program Files (x86)/CURL
exec_prefix=${prefix}
libdir=C:/Program Files (x86)/CURL/lib
includedir=${prefix}/include
supported_protocols="HTTP IPFS IPNS"
supported_features="IPv6 UnixSockets zstd AsynchDNS Largefile alt-svc HSTS NTLM threadsafe"

Name: libcurl
URL: https://curl.se/
Description: Library to transfer files with ftp, http, etc.
Version: 8.7.0-DEV
Libs: -L${libdir} -lcurl  -lws2_32 -lbcrypt kernel32.lib -ladvapi32 -lcrypt32
Libs.private:  -lws2_32 -lbcrypt kernel32.lib -ladvapi32 -lcrypt32
Cflags: -I${includedir} -DCURL_STATICLIB
