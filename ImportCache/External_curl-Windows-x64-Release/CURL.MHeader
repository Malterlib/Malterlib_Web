%Target "Com_CURL_curlt-client-hx-download"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/curl'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zstd/lib`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_curl`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/boringssl/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"CURL_NO_OLDIES",
			"CURL_STATICLIB",
			"HAVE_CONFIG_H",
			"_CRT_NONSTDC_NO_DEPRECATE",
			"_CRT_SECURE_NO_DEPRECATE"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "CURL_curlt-client-hx-download"
	Target.BaseFileName "curlt-client-hx-download"
	%Group "tests"
	{
		%File `@('../../../../External/curl'->MakeAbsolute())/tests/http/clients/hx-download.c`
		{
			Compile.Type "C"
		}
	}
	%Dependency "Lib_CURL_libcurl_static"
}
%Target "Com_CURL_curlt-client-hx-upload"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/curl'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zstd/lib`->MakeAbsolute(),
