	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "src"
				{
					%File `@(CMakeIntermediateDirectory)/External_curl/src/tool_hugehelp.c`->MakeAbsolute()
					{
						Compile.AllowNonExisting true
						Compile.Type "C"
					}
					%File `@('.'->MakeAbsolute())/src/tool_hugehelp.c.rule`
					{
						Compile
						{
							Type "Custom"
							Custom_CommandLine `MToolCMake -E echo "#include \\"tool_hugehelp.h\\"" > tool_hugehelp.c`
							AllowNonExisting true
							Custom_WorkingDirectory `@('.'->MakeAbsolute())/src`->MakeAbsolute()
							Custom_Outputs [
								`@(CMakeIntermediateDirectory)/External_curl/src/tool_hugehelp.c`->MakeAbsolute()
							]
							Custom_Inputs [
								`@('../../../../External/curl'->MakeAbsolute())/src/tool_hugehelp.h`->MakeAbsolute()
							]
						}
					}
				}
			}
		}
	}
	%Group "lib"
	{
		%File `@('../../../../External/curl'->MakeAbsolute())/lib/base64.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../External/curl'->MakeAbsolute())/lib/dynbuf.c`
		{
			Compile.Type "C"
		}
	}
}
