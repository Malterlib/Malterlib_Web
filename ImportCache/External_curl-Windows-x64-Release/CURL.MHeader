%Target "Tool_CURL_test-quiet"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_test-quiet"
	Target.BaseFileName "test-quiet"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "tests"
				{
					%Group "CMakeFiles"
					{
						%File `@('.'->MakeAbsolute())/tests/CMakeFiles/test-quiet.rule`
						{
							Compile
							{
								Type "Custom"
								Custom_CommandLine `perl.exe @(`@('../../../../External/curl'->MakeAbsolute())/tests/runtests.pl`->MakeAbsolute()->EscapeHost()) -a -s $$TFLAGS`
								AllowNonExisting true
								Disabled false
								Custom_WorkingDirectory `@('.'->MakeAbsolute())/tests`->MakeAbsolute()
								Custom_Outputs []
								Custom_Inputs []
							}
						}
					}
				}
			}
		}
	}
	%Dependency "Tool_CURL_testdeps"
	{
		Dependency.Link false
	}
}
