Property.CMakeOutputPath_CURL: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Tool_CURL_curl_uninstall"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CURL_curl_uninstall"
	Target.BaseFileName "curl_uninstall"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "CMakeFiles"
				{
					%File `@('.'->MakeAbsolute())/CMakeFiles/curl_uninstall.rule`
					{
						Compile
						{
							Type "Custom"
							Custom_CommandLine `MToolCMake -P @(`@('.'->MakeAbsolute())/CMake/cmake_uninstall.cmake`->MakeAbsolute()->EscapeHost())`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('.'->MakeAbsolute())`->MakeAbsolute()
							Custom_Outputs []
							Custom_Inputs []
						}
					}
				}
			}
		}
	}
}
%Target "Lib_CURL_curlu"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/curl'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zstd/lib`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_curl`->MakeAbsolute(),
			`@('../../../../External/curl'->MakeAbsolute())/lib`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/boringssl/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BUILDING_LIBCURL",
			"CURL_STATICLIB",
			"HAVE_CONFIG_H",
			"UNITTESTS",
			"_CRT_NONSTDC_NO_DEPRECATE",
			"_CRT_SECURE_NO_DEPRECATE"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "CURL_curlu"
	Target.BaseFileName "curlu"
	%Group "lib"
	{
		%File `@('../../../../External/curl'->MakeAbsolute())/lib/altsvc.h`
