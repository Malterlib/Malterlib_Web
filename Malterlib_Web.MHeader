	Name: "Malterlib_Web"
	, Properties: {
		MalterlibTestDependencies: "Lib_Malterlib_Web"
		MalterlibTestFiles: "../Test/*"->MakeAbsolute()
		MalterlibTestExtraGroups: "{Test}/{Malterlib_Web}"
	}
}
